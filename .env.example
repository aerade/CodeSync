# CodeSync — Self-Hosted Environment Variables
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# PostgreSQL password (used by Docker Compose)
POSTGRES_PASSWORD=changeme

# Full connection string (set automatically by Docker Compose)
# DATABASE_URL=postgres://codesync:changeme@localhost:5432/codesync

# ──────────────────────────────────────────────
# Authentication (Clerk)
# ──────────────────────────────────────────────
# Get these from https://dashboard.clerk.com
# Leave empty to use guest-only mode
CLERK_SECRET_KEY=

# ──────────────────────────────────────────────
# AI Features
# ──────────────────────────────────────────────
# At least one AI key is required for AI chat/review features
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────
# App Settings
# ──────────────────────────────────────────────
NODE_ENV=production
PORT=8080
