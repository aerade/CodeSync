    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "^1.1.1",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "date-fns": "^3.6.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "embla-carousel-react": "^8.6.0",
