{
  "name": "@workspace/desktop",
  "version": "1.0.0",
  "description": "CodeSync Desktop — collaborative IDE",
  "author": {
    "name": "CodeSync",
    "email": "hello@codesync.dev"
  },
  "homepage": "https://github.com/your-org/codesync",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "electron:vite-build": "cross-env ELECTRON_BUILD=1 vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "electron:compile": "tsc --project tsconfig.electron.json && node scripts/rename-to-cjs.mjs",
    "electron:dev": "pnpm run server:build && concurrently \"pnpm run dev\" \"wait-on http://localhost:21098/desktop/ && electron .\"",
    "server:build": "cd server && node build.mjs",
    "electron:build": "pnpm run server:build && pnpm run electron:vite-build && pnpm run electron:compile && electron-builder build --config electron-builder.yml",
    "electron:build:win": "pnpm run server:build && pnpm run electron:vite-build && pnpm run electron:compile && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder build --win --config electron-builder.yml",
    "electron:build:mac": "pnpm run server:build && pnpm run electron:vite-build && pnpm run electron:compile && electron-builder build --mac --config electron-builder.yml",
    "electron:build:linux": "pnpm run server:build && pnpm run electron:vite-build && pnpm run electron:compile && electron-builder build --linux --config electron-builder.yml",
    "build:full": "pnpm run server:build && pnpm run electron:vite-build && pnpm run electron:compile && electron-builder build --config electron-builder.yml"
  },
  "main": "dist/electron-main/main.cjs",
  "dependencies": {
    "@clerk/react": "^6.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "monaco-editor": "^0.55.1",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-aspect-ratio": "^1.1.3",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-hover-card": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-menubar": "^1.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.6",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-toggle": "^1.1.3",
    "@radix-ui/react-toggle-group": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@replit/vite-plugin-runtime-error-modal": "*",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-query": "catalog:",
